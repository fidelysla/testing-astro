---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout>
	<div>
		<div class="fixed top-4 right-4 z-50">
			<div class="relative inline-block text-left">
				<select
					id="language-switcher"
					class="appearance-none rounded-md border border-gray-300 bg-white px-3 py-2 pr-8 text-sm font-medium text-gray-700 hover:bg-gray-50 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500 focus:outline-none"
				>
					<option value="/" selected="">English</option>
					<option value="/es">Español</option>
				</select>
			</div>
		</div>
		<div
			class="min-h-screen bg-gradient-to-br from-indigo-500 to-purple-600"
		>
			<div class="mx-auto max-w-6xl px-5">
				<header class="mb-12 pt-12 text-center text-white">
					<h1 class="mb-3 text-4xl font-bold sm:text-5xl md:text-6xl">
						Astro Pro
					</h1>
					<p class="text-lg opacity-90 sm:text-xl">
						Full-stack Astro app with Authentication
					</p>
				</header>
				<main class="flex flex-col items-center gap-10">
					<div
						class="w-full max-w-lg rounded-xl bg-white p-10 text-center shadow-2xl"
					>
						<h2 class="mb-3 text-2xl text-gray-700">Get Started</h2>
						<p class="mb-8 text-gray-500">
							Sign in to access your dashboard or create a new
							account.
						</p>
						<div
							class="flex flex-col justify-center gap-4 sm:flex-row"
						>
							<a
								href="/login"
								class="rounded-md bg-indigo-500 px-6 py-3 font-semibold text-white no-underline transition-all hover:-translate-y-0.5 hover:shadow-lg"
							>
								Sign In
							</a>
							<a
								href="/register"
								class="rounded-md bg-gray-100 px-6 py-3 font-semibold text-gray-700 no-underline transition-all hover:-translate-y-0.5 hover:shadow-lg"
							>
								Create Account
							</a>
						</div>
					</div>
					<div
						class="grid w-full max-w-4xl grid-cols-1 gap-5 md:grid-cols-3"
					>
						<div
							class="rounded-xl bg-white/10 p-8 text-center text-white backdrop-blur-lg"
						>
							<h3 class="mb-3 text-lg">🔐 Authentication</h3>
							<p class="opacity-90">
								Secure authentication with better-auth and
								Prisma
							</p>
						</div>
						<div
							class="rounded-xl bg-white/10 p-8 text-center text-white backdrop-blur-lg"
						>
							<h3 class="mb-3 text-lg">🗄️ Database</h3>
							<p class="opacity-90">
								PostgreSQL database with Prisma ORM
							</p>
						</div>
						<div
							class="rounded-xl bg-white/10 p-8 text-center text-white backdrop-blur-lg"
						>
							<h3 class="mb-3 text-lg">🚀 Astro</h3>
							<p class="opacity-90">
								Fast, modern web framework with TypeScript
							</p>
						</div>
					</div>
				</main>
			</div>
		</div>
	</div>
</MainLayout>
