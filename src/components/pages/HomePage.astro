---
import MainLayout from "@/layouts/MainLayout.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import LangPicker from "@/components/LangPicker.astro";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<MainLayout>
  <LangPicker />
  <div class="min-h-screen bg-gradient-to-br from-indigo-500 to-purple-600">
    <div class="mx-auto max-w-6xl px-5">
      <header class="mb-12 pt-12 text-center text-white">
        <h1 class="mb-3 text-4xl font-bold sm:text-5xl md:text-6xl">
          | Astro Pro
        </h1>
        <p class="text-lg opacity-90 sm:text-xl">{t("home.subtitle")}</p>
      </header>
      <main class="flex flex-col items-center gap-10">
        <div
          class="w-full max-w-lg rounded-xl bg-white p-10 text-center shadow-2xl"
        >
          <h2 class="mb-3 text-2xl text-gray-700">{t("home.getStarted")}</h2>
          <p class="mb-8 text-gray-500">{t("home.getStartedDesc")}</p>
          <div class="flex flex-col justify-center gap-4 sm:flex-row">
            <a
              href=`/${lang}/login`
              class="rounded-md bg-indigo-500 px-6 py-3 font-semibold text-white no-underline transition-all hover:-translate-y-0.5 hover:shadow-lg"
            >
              {t("home.signIn")}
            </a>
            <a
              href=`/${lang}/register`
              class="rounded-md bg-gray-100 px-6 py-3 font-semibold text-gray-700 no-underline transition-all hover:-translate-y-0.5 hover:shadow-lg"
            >
              {t("home.createAccount")}
            </a>
          </div>
        </div>
        <div class="grid w-full max-w-4xl grid-cols-1 gap-5 md:grid-cols-3">
          <div
            class="rounded-xl bg-white/10 p-8 text-center text-white backdrop-blur-lg"
          >
            <h3 class="mb-3 text-lg">{t("home.features.auth.title")}</h3>
            <p class="opacity-90">{t("home.features.auth.desc")}</p>
          </div>
          <div
            class="rounded-xl bg-white/10 p-8 text-center text-white backdrop-blur-lg"
          >
            <h3 class="mb-3 text-lg">{t("home.features.db.title")}</h3>
            <p class="opacity-90">{t("home.features.db.desc")}</p>
          </div>
          <div
            class="rounded-xl bg-white/10 p-8 text-center text-white backdrop-blur-lg"
          >
            <h3 class="mb-3 text-lg">{t("home.features.astro.title")}</h3>
            <p class="opacity-90">{t("home.features.astro.desc")}</p>
          </div>
        </div>
      </main>
    </div>
  </div>
</MainLayout>;
